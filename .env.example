# Kontakt RODO / regulamin (wyświetlany na stronach prawnych)
LEGAL_CONTACT_EMAIL="kontakt@twoja-domena.pl"
# NEXT_PUBLIC_LEGAL_CONTACT_EMAIL="kontakt@twoja-domena.pl"

# Database (Neon / Supabase)
# Neon: użyj sslmode=verify-full (unika ostrzeżenia pg o sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=verify-full"

# AI (Faza 1)
OPENAI_API_KEY="sk-proj-your-key-here"
OPENAI_MODEL="gpt-4o-mini"

# Mapa (Mapbox — styl Google Maps) https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
# OPENROUTESERVICE_API_KEY=""

# Weather (Faza 3) — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=""

# Rate limiting (produkcja na Vercel — zalecane; bez tego limit per IP jest tylko w pamięci instancji)
# Utwórz bazę na https://console.upstash.com → REST API
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# Auth / e-mail (Faza 5 — dodane na końcu projektu)
# AUTH_SECRET, AUTH_URL, AUTH_GOOGLE_*, EMAIL_SERVER, EMAIL_FROM
