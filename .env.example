# Database (Neon / Supabase)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js — openssl rand -base64 32 (min. 32 znaki; bez zmian po pierwszym logowaniu)
AUTH_SECRET="your-random-secret-here"
AUTH_URL="http://localhost:3000"
# Po zmianie AUTH_SECRET usuń ciasteczka authjs.* w przeglądarce

# AI (Faza 1)
OPENAI_API_KEY="sk-proj-your-key-here"
OPENAI_MODEL="gpt-4o-mini"

# Google OAuth (Faza 5) — https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Mapa (Mapbox — styl Google Maps) https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
# OPENROUTESERVICE_API_KEY=""

# Weather (Faza 3) — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=""

# Redis cache (Faza 7)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
