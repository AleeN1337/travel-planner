# Database (Neon / Supabase)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js — openssl rand -base64 32 (min. 32 znaki; bez zmian po pierwszym logowaniu)
AUTH_SECRET="your-random-secret-here"
# Lokalnie: http://localhost:3000 | Produkcja (Vercel): https://twoja-app.vercel.app
AUTH_URL="http://localhost:3000"
# Po zmianie AUTH_SECRET usuń ciasteczka authjs.* w przeglądarce

# AI (Faza 1)
OPENAI_API_KEY="sk-proj-your-key-here"
OPENAI_MODEL="gpt-4o-mini"

# Google OAuth (opcjonalnie) — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# E-mail — aktywacja konta (wymagane na produkcji: jedna z opcji poniżej)
# Opcja A — Resend (https://resend.com/api-keys): jedna zmienna, wygodne na Vercel
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Planer Podróży <onboarding@resend.dev>"  # test; produkcja: zweryfikowana domena
# Opcja B — SMTP. Przykład Gmail: smtp://user@gmail.com:haslo-aplikacji@smtp.gmail.com:587
EMAIL_SERVER=""
EMAIL_FROM="Planer Podróży <noreply@twoja-domena.pl>"
# Lokalnie bez SMTP/Resend: link aktywacyjny w terminalu (npm run dev)

# Mapa (Mapbox — styl Google Maps) https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
# OPENROUTESERVICE_API_KEY=""

# Weather (Faza 3) — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=""

# Redis cache (Faza 7)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
