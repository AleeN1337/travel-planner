// Travel Planner — schema (Faza 0)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum PlanStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum BudgetLevel {
  LOW
  MEDIUM
  HIGH
}

enum TravelStyle {
  CULTURE
  FOOD
  NATURE
  NIGHTLIFE
  FAMILY
  MIXED
}

enum PaceLevel {
  RELAXED
  BALANCED
  INTENSE
}

enum TransportMode {
  WALKING
  PUBLIC_TRANSIT
  CAR
  MIXED
}

enum TimeOfDay {
  MORNING
  AFTERNOON
  EVENING
}

enum PlanVariant {
  STANDARD
  BUDGET
  PREMIUM
}

enum SharePermission {
  VIEW
  EDIT
}

enum VoteType {
  WANT
  SKIP
}

// --- Auth (NextAuth / Auth.js) ---

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  tripPlans     TripPlan[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Core trip planning ---

model TripPlan {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestToken     String?       @unique
  destination    String
  countryCode    String?
  daysCount      Int
  startDate      DateTime?
  budgetLevel    BudgetLevel
  travelStyle    TravelStyle
  paceLevel      PaceLevel
  transportMode  TransportMode
  travelParty    String?
  childrenAges   Json?
  mustSee        String?       @db.Text
  avoid          String?       @db.Text
  accommodationArea String?
  arrivalAirportCode String?
  arrivalAirportName String?
  departureAirportCode String?
  departureAirportName String?
  adultsCount      Int           @default(2)
  mobilityNeeds    String?
  firstTimeVisit   Boolean       @default(true)
  travelStyles     Json?
  dietaryNotes     String?       @db.Text
  foodStandard     String?
  accommodationType String?
  quietEvenings    Boolean       @default(false)
  preferredStartHour Int?
  stylePriorityNote String?      @db.Text
  budgetIncludes   Json?
  maxTravelBetween String?
  hasTransitPass   Boolean       @default(false)
  carRental        Boolean       @default(false)
  lightFirstDay    Boolean       @default(false)
  tripOccasion     String?
  weatherPreference String?
  languageComfort  String?
  safetyNotes      String?       @db.Text
  additionalNotes  String?       @db.Text
  variant        PlanVariant   @default(STANDARD)
  totalBudgetMin Float?
  totalBudgetMax Float?
  currency       String        @default("PLN")
  paramsHash     String?
  status              PlanStatus    @default(DRAFT)
  errorMessage        String?
  generationProgress  Int?
  generationStage     String?

  days              PlanDay[]
  checklistItems    ChecklistItem[]
  weatherSnapshots  WeatherSnapshot[]
  shareLinks        ShareLink[]
  costSplits        CostSplit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([paramsHash])
  @@index([guestToken])
}

model PlanDay {
  id         String   @id @default(cuid())
  tripPlanId String
  tripPlan   TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  dayNumber  Int
  title      String?
  summary    String?

  activities        Activity[]
  planBAlternatives PlanBAlternative[]

  @@unique([tripPlanId, dayNumber])
}

model Activity {
  id           String    @id @default(cuid())
  planDayId    String
  planDay      PlanDay   @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  timeOfDay    TimeOfDay
  orderIndex   Int
  title        String
  description  String?   @db.Text
  locationName String?
  latitude     Float?
  longitude    Float?
  durationMin  Int?
  costMin      Float?
  costMax      Float?
  category     String?
  isLocalTip   Boolean   @default(false)

  votes ActivityVote[]

  @@index([planDayId])
}

model PlanBAlternative {
  id          String  @id @default(cuid())
  planDayId   String
  planDay     PlanDay @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  reason      String
  title       String
  description String? @db.Text
}

model ChecklistItem {
  id          String   @id @default(cuid())
  tripPlanId  String
  tripPlan    TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  label       String
  category    String?
  resourceUrl String?
  isChecked   Boolean  @default(false)
  orderIndex  Int      @default(0)
}

model WeatherSnapshot {
  id          String   @id @default(cuid())
  tripPlanId  String
  tripPlan    TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  date        DateTime
  tempMin     Float?
  tempMax     Float?
  condition   String?
  suggestion  String?  @db.Text
  fetchedAt   DateTime @default(now())
}

// --- Collaboration ---

model ShareLink {
  id         String          @id @default(cuid())
  tripPlanId String
  tripPlan   TripPlan        @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  token      String          @unique @default(cuid())
  permission SharePermission @default(VIEW)
  expiresAt  DateTime?
  createdAt  DateTime        @default(now())
}

model ActivityVote {
  id           String     @id @default(cuid())
  activityId   String
  activity     Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  voterName    String?
  voterToken   String
  vote         VoteType
  createdAt    DateTime   @default(now())

  @@unique([activityId, voterToken])
}

model CostSplit {
  id          String   @id @default(cuid())
  tripPlanId  String
  tripPlan    TripPlan @relation(fields: [tripPlanId], references: [id], onDelete: Cascade)
  label       String
  amount      Float
  paidBy      String
  splitBetween String[] // participant names
  createdAt   DateTime @default(now())
}
